  const MIN_DUUR_S = 5;
  const MAX_DUUR_S = 10;

  function animeerNaar(element: SVGElement, naarX: number, pct: number) {
    const vanX = START_X;
    const duur = (MIN_DUUR_S + (MAX_DUUR_S - MIN_DUUR_S) * pct) * 1000;
    const start = performance.now();
    element.setAttribute("transform", `translate(${vanX}, ${WEG_Y})`);
    function stap(nu: number) {
      const t = Math.min((nu - start) / duur, 1);
      const ease = 1 - Math.pow(1 - t, 3);
      const x = vanX + (naarX - vanX) * ease;
      element.setAttribute("transform", `translate(${x}, ${WEG_Y})`);
      if (t < 1) requestAnimationFrame(stap);
    }
    setTimeout(() => requestAnimationFrame(stap), 150);
  }

  async function laadVoortgang() {
    const donaties = await haalDonaties();
    const totaal = berekenTotaal(donaties);
    const pct = Math.min(totaal / DOEL, 1);

    const fiets = document.getElementById("fiets-groep") as SVGElement | null;
    if (fiets) animeerNaar(fiets, START_X + (EIND_X - START_X) * pct, pct);

    const bedragGetal = document.getElementById("bedrag-getal");
    if (bedragGetal) {
      const duur = (MIN_DUUR_S + (MAX_DUUR_S - MIN_DUUR_S) * pct) * 1000;
      const start = performance.now();
      function tellerStap(nu: number) {
        const t = Math.min((nu - start) / duur, 1);
        const ease = 1 - Math.pow(1 - t, 3);
        bedragGetal!.textContent = Math.round(totaal * ease).toLocaleString(
          "nl-NL",
          { style: "currency", currency: "EUR", maximumFractionDigits: 0 },
        );
        if (t < 1) requestAnimationFrame(tellerStap);
      }
      setTimeout(() => requestAnimationFrame(tellerStap), 150);
    }

    const donateursGetal = document.getElementById("donateurs-getal");
    if (donateursGetal) {
      const duur = (MIN_DUUR_S + (MAX_DUUR_S - MIN_DUUR_S) * pct) * 1000;
      const start = performance.now();
      const aantalDonateurs = donaties.length;
      function donateursStap(nu: number) {
        const t = Math.min((nu - start) / duur, 1);
        const ease = 1 - Math.pow(1 - t, 3);
        donateursGetal!.textContent = String(
          Math.round(aantalDonateurs * ease),
        );
        if (t < 1) requestAnimationFrame(donateursStap);
      }
      setTimeout(() => requestAnimationFrame(donateursStap), 150);
    }

    const balk = document.getElementById(
      "fiets-voortgang-balk",
    ) as HTMLElement | null;
    if (balk)
      setTimeout(() => {
        balk.style.transition = `width ${MIN_DUUR_S + (MAX_DUUR_S - MIN_DUUR_S) * pct}s cubic-bezier(0.215, 0.61, 0.355, 1)`;
        balk.style.width = `${pct * 100}%`;
      }, 200);
  }

  function herstart() {
    const balk = document.getElementById(
      "fiets-voortgang-balk",
    ) as HTMLElement | null;
    if (balk) {
      balk.style.transition = "none";
      balk.style.width = "0%";
    }
    const fiets = document.getElementById("fiets-groep") as SVGElement | null;
    if (fiets)
      fiets.setAttribute("transform", `translate(${START_X}, ${WEG_Y})`);
    const bedragGetal = document.getElementById("bedrag-getal");
    if (bedragGetal) bedragGetal.textContent = "—";
    const donateursGetal = document.getElementById("donateurs-getal");
    if (donateursGetal) donateursGetal.textContent = "—";
    laadVoortgang();
  }

  document.getElementById("herstart-knop")?.addEventListener("click", herstart);
  laadVoortgang();
</script>
