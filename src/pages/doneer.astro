---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Doneer"
  beschrijving="Steun Eva's fietstocht van 100 km met een belofte in cent per kilometer."
>
  <section
    class="min-h-screen py-20 px-4 bg-gradient-to-b from-sky-50 via-blue-50 to-green-50"
  >
    <div class="max-w-lg mx-auto">
      <div class="text-center mb-10">
        <div class="text-5xl mb-3">💶💰💵</div>
        <h1 class="text-4xl font-black mb-3">
          <span class="gradient-tekst">Doneer</span>
        </h1>
        <p class="text-gray-500">
          Kies hoeveel cent je per kilometer doneert.
          <br />
          Bij 100 km is 1 ct/km dus € 1,00 totaal — elk beetje helpt!
          <br />
          Betaling gaat buiten de website om — we nemen contact op!
        </p>
      </div>

      <div
        id="succes-bericht"
        class="hidden bg-turkoois/10 border border-turkoois rounded-2xl p-6 text-center mb-6"
      >
        <div class="text-4xl mb-2">🎉</div>
        <h2 class="text-xl font-black text-turkoois mb-1">Bedankt!</h2>
        <p class="text-gray-600 text-sm">
          Jouw belofte is geregistreerd. We nemen na de tocht contact op!
        </p>
      </div>

      <form
        id="donatie-formulier"
        class="bg-white rounded-2xl shadow-lg p-8 space-y-6"
        novalidate
      >
        <!-- Honeypot: verborgen voor mensen, zichtbaar voor bots -->
        <input
          type="text"
          name="website"
          class="hidden"
          tabindex="-1"
          autocomplete="off"
        />

        <div>
          <label for="naam" class="block text-sm font-bold text-gray-700 mb-1"
            >Jouw naam *</label
          >
          <input
            type="text"
            id="naam"
            maxlength="100"
            placeholder="Bijv. Simone Biles"
            class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 focus:border-turkoois focus:outline-none transition-colors"
            aria-describedby="fout-naam"
          />
          <p id="fout-naam" class="hidden text-red-500 text-sm mt-1">
            Vul je naam in
          </p>
        </div>

        <div>
          <label
            for="contact"
            class="block text-sm font-bold text-gray-700 mb-1">Contact *</label
          >
          <p class="text-sm text-gray-500 mb-2">
            Hoe kunnen we contact met je opnemen?<br />
            <span class="text-gray-400"
              >Wordt niet publiek gedeeld, alleen nodig om na afloop contact met
              je op te nemen over je donatie.</span
            >
          </p>
          <input
            type="text"
            id="contact"
            maxlength="200"
            placeholder="Bijv. 06-12345678 of simone@biles.com"
            class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 focus:border-turkoois focus:outline-none transition-colors"
            aria-describedby="fout-contact"
          />
          <p id="fout-contact" class="hidden text-red-500 text-sm mt-1">
            Vul je contactgegevens in
          </p>
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-3"
            >Cent per kilometer *</label
          >
          <div class="grid grid-cols-3 gap-2 mb-3">
            {
              [1, 5, 10, 25, 50, 100].map((ct) => (
                <button
                  type="button"
                  class="preset-knop border-2 border-gray-200 rounded-xl py-3 font-bold text-sm hover:border-turkoois hover:text-turkoois transition-all"
                  data-centen={String(ct)}
                >
                  {ct} cent/km
                </button>
              ))
            }
          </div>
          <div class="flex items-center gap-3">
            <input
              type="number"
              id="centen-per-km"
              min="1"
              max="1000"
              step="1"
              placeholder="b.v. 5"
              class="w-24 border-2 border-gray-200 rounded-xl px-3 py-3 focus:border-turkoois focus:outline-none transition-colors text-center"
              aria-describedby="fout-bedrag"
            />
            <span class="text-gray-500 font-medium whitespace-nowrap"
              >cent/km</span
            >
            <span class="text-sm text-gray-500 whitespace-nowrap">
              = <span id="totaal-preview" class="font-bold text-turkoois"
                >€ 0,00</span
              > bij 100 km
            </span>
          </div>
          <p id="fout-bedrag" class="hidden text-red-500 text-sm mt-1">
            Kies een geldig aantal cent (1 – 1000 ct/km)
          </p>
        </div>

        <div>
          <label
            for="bericht"
            class="block text-sm font-bold text-gray-700 mb-1"
          >
            Bericht <span class="text-gray-400 font-normal"
              >(optioneel, max 200 tekens)</span
            >
          </label>
          <textarea
            id="bericht"
            maxlength="200"
            rows="3"
            placeholder="Bijv. Succes meid! Je kan het!"
            class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 focus:border-turkoois focus:outline-none transition-colors resize-none"
          ></textarea>
        </div>

        <div>
          <label for="vraag" class="block text-sm font-bold text-gray-700 mb-1">
            Vraag aan Eva <span class="text-gray-400 font-normal"
              >(optioneel — Eva beantwoordt ze persoonlijk!)</span
            >
          </label>
          <textarea
            id="vraag"
            maxlength="200"
            rows="2"
            placeholder="Bijv. Wat neem je allemaal mee tijdens de tocht?"
            class="w-full border-2 border-gray-200 rounded-xl px-4 py-3 focus:border-turkoois focus:outline-none transition-colors resize-none"
          ></textarea>
        </div>

        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="publiek"
            checked
            class="mt-1 w-4 h-4 accent-turkoois"
          />
          <label for="publiek" class="text-sm text-gray-600">
            Mijn naam, bericht en vraag mogen publiek zichtbaar zijn op de
            website (zet dit uit voor een anonieme donatie)
          </label>
        </div>

        <button
          type="submit"
          id="submit-knop"
          class="w-full bg-oranje hover:bg-orange-400 text-white font-black text-lg py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-oranje/30"
        >
          <span class="fiets-rechts">🚴</span> Beloof mijn donatie! 💰
        </button>

        <div
          id="fout-bericht"
          class="hidden bg-red-50 border border-red-200 rounded-xl p-4 text-red-600 text-sm text-center"
        >
        </div>
      </form>
    </div>
  </section>
</Layout>

<script>
  import { voegDonatieToe } from "../lib/donations";
  import { formatEuro } from "../lib/dom";

  // Preset knoppen
  document.querySelectorAll(".preset-knop").forEach((knop) => {
    knop.addEventListener("click", () => {
      const centen = (knop as HTMLElement).dataset.centen ?? "";
      (document.getElementById("centen-per-km") as HTMLInputElement).value =
        centen;
      document
        .querySelectorAll(".preset-knop")
        .forEach((k) =>
          k.classList.remove(
            "border-turkoois",
            "text-turkoois",
            "bg-turkoois/5",
          ),
        );
      knop.classList.add("border-turkoois", "text-turkoois", "bg-turkoois/5");
      updateVooruitkijk();
    });
  });

  function updateVooruitkijk() {
    const invoer = document.getElementById("centen-per-km") as HTMLInputElement;
    const preview = document.getElementById("totaal-preview");
    const centen = parseInt(invoer?.value ?? "0") || 0;
    if (preview) preview.textContent = formatEuro(centen);
  }

  document
    .getElementById("centen-per-km")
    ?.addEventListener("input", updateVooruitkijk);

  function gooidConfetti() {
    const kleuren = ["#00C4B4", "#FF6B35", "#FFD700", "#ffffff"];
    for (let i = 0; i < 80; i++) {
      const stuk = document.createElement("div");
      const kleur = kleuren[Math.floor(Math.random() * kleuren.length)];
      const isRond = Math.random() > 0.5;
      const duur = 0.8 + Math.random() * 1.5;
      const rotation = Math.random() * 720;
      const startX = Math.random() * 100;

      stuk.style.cssText = [
        "position:fixed",
        "width:10px",
        "height:10px",
        `background:${kleur}`,
        `border-radius:${isRond ? "50%" : "2px"}`,
        `left:${startX}vw`,
        "top:-10px",
        "z-index:9999",
        "pointer-events:none",
      ].join(";");

      const animNaam = `confetti-val-${i}-${Date.now()}`;
      const style = document.createElement("style");
      style.textContent = `@keyframes ${animNaam} { to { transform: translateY(110vh) rotate(${rotation}deg); opacity: 0; } }`;
      stuk.style.animation = `${animNaam} ${duur}s ease-in forwards`;

      document.head.appendChild(style);
      document.body.appendChild(stuk);
      setTimeout(
        () => {
          stuk.remove();
          style.remove();
        },
        Math.ceil(duur * 1000) + 200,
      );
    }
  }

  function verbergVeldFout(veldId: string, foutId: string) {
    const veld = document.getElementById(veldId);
    const foutEl = document.getElementById(foutId);
    veld?.classList.remove("border-red-400");
    foutEl?.classList.add("hidden");
  }

  // Wis veldfouten zodra de gebruiker begint met typen
  ["naam", "contact"].forEach((id) => {
    document.getElementById(id)?.addEventListener("input", () => {
      verbergVeldFout(id, `fout-${id}`);
    });
  });
  document.getElementById("centen-per-km")?.addEventListener("input", () => {
    verbergVeldFout("centen-per-km", "fout-bedrag");
  });

  document
    .getElementById("donatie-formulier")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Honeypot check
      const honeypot =
        (document.querySelector('input[name="website"]') as HTMLInputElement)
          ?.value ?? "";
      if (honeypot) return; // Stille spam-blokkering

      const knop = document.getElementById("submit-knop") as HTMLButtonElement;

      // Wis alle fouten
      ["naam", "contact"].forEach((id) => verbergVeldFout(id, `fout-${id}`));
      verbergVeldFout("centen-per-km", "fout-bedrag");

      // Valideer verplichte velden
      const naam = (
        (document.getElementById("naam") as HTMLInputElement)?.value ?? ""
      ).trim();
      const contact = (
        (document.getElementById("contact") as HTMLInputElement)?.value ?? ""
      ).trim();
      const centenInvoer =
        (document.getElementById("centen-per-km") as HTMLInputElement)?.value ??
        "";
      const centenPerKm = parseInt(centenInvoer);

      let heeftFout = false;

      if (!naam) {
        document.getElementById("naam")?.classList.add("border-red-400");
        document.getElementById("fout-naam")?.classList.remove("hidden");
        heeftFout = true;
      }

      if (!contact) {
        document.getElementById("contact")?.classList.add("border-red-400");
        document.getElementById("fout-contact")?.classList.remove("hidden");
        heeftFout = true;
      }

      if (isNaN(centenPerKm) || centenPerKm < 1 || centenPerKm > 1000) {
        document
          .getElementById("centen-per-km")
          ?.classList.add("border-red-400");
        document.getElementById("fout-bedrag")?.classList.remove("hidden");
        heeftFout = true;
      }

      if (heeftFout) return;

      if (knop) {
        knop.disabled = true;
        knop.textContent = "⏳ Versturen…";
      }

      try {
        const berichtWaarde = (
          (document.getElementById("bericht") as HTMLTextAreaElement)?.value ??
          ""
        ).trim();
        const vraagWaarde = (
          (document.getElementById("vraag") as HTMLTextAreaElement)?.value ?? ""
        ).trim();
        const publiek =
          (document.getElementById("publiek") as HTMLInputElement)?.checked ??
          false;

        await voegDonatieToe({
          naam,
          contact,
          bedragPerKm: centenPerKm / 100,
          bericht: berichtWaarde || undefined,
          vraag: vraagWaarde || undefined,
          publiek,
        });

        document.getElementById("donatie-formulier")?.classList.add("hidden");
        document.getElementById("succes-bericht")?.classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
        gooidConfetti();
      } catch (err) {
        const fout = document.getElementById("fout-bericht");
        const bericht =
          err instanceof Error
            ? err.message
            : "Er ging iets mis. Probeer het opnieuw.";
        if (fout) {
          fout.textContent = bericht; // textContent — geen XSS risico
          fout.classList.remove("hidden");
        }
        if (knop) {
          knop.disabled = false;
          const fietsSpan = document.createElement("span");
          fietsSpan.className = "fiets-rechts";
          fietsSpan.textContent = "🚴";
          knop.replaceChildren(
            fietsSpan,
            document.createTextNode(" Beloof mijn donatie!"),
          );
        }
      }
    });
</script>
