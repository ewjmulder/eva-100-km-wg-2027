---
import Layout from "../layouts/Layout.astro";

// Foto type:
//   bestand:    bestandsnaam in public/media/vorige-tochten/<km>/
//   tekst:      optioneel onderschrift (altijd eronder)
//   orientatie: 'landscape'     → volle breedte, 16:9 uitsnede
//               'portrait-high' → gecentreerd, bovenste deel getoond
//               'portrait-mid'  → gecentreerd, middelste deel getoond
//               'portrait-low'  → gecentreerd, onderste deel getoond
//               mp3-bestanden: orientatie wordt genegeerd
type Orientatie =
  | "landscape"
  | "portrait-high"
  | "portrait-mid"
  | "portrait-low";
type Foto = { bestand: string; tekst?: string; orientatie?: Orientatie };

const fotos60km: Foto[] = [
  {
    bestand: "groen.webp",
    tekst: "De tocht ging over paadjes door het groen ...",
    orientatie: "portrait-high",
  },
  {
    bestand: "kanaal.webp",
    tekst: "... en langs het water",
    orientatie: "landscape",
  },
  {
    bestand: "trufa.mp3",
    tekst:
      "Eva stuurde dit enthousiaste voice bericht naar haar moeder. Trufa was een hond waar ze pas daarvoor op gepast had.",
  },
  {
    bestand: "nijntje.webp",
    tekst: "In Utrecht kwam Eva Nijntje tegen",
    orientatie: "landscape",
  },
  { bestand: "peace.webp", tekst: "Eva genoot!", orientatie: "landscape" },
  {
    bestand: "bijnaachterhangen.mp3",
    tekst:
      "Vlak daarna, op ongeveer 20 km, zei ze dit, maar daar kwam het voorlopig nog niet van!",
  },
  {
    bestand: "kasteel.webp",
    tekst: "Verder ging het, langs een kasteel",
    orientatie: "portrait-mid",
  },
  {
    bestand: "geocache.webp",
    tekst: "Onderweg vond ze nog een geocache",
    orientatie: "portrait-mid",
  },
  {
    bestand: "whatsapp.webp",
    tekst: "Screenshot van het Whatsapp gesprek tussen de verblufte ouders",
    orientatie: "landscape",
  },
  {
    bestand: "achterhangen.webp",
    tekst:
      "En toen, na 60km, moest Eva toch gaan achterhangen. Niet omdat ze dat zelf wilde, maar omdat ze anders de zee niet meer zouden halen. Na wat tegenstribbelen gaf ze toe, eigenlijk was ze toch ook al best wel moe :)",
    orientatie: "portrait-low",
  },
  {
    bestand: "laatstekm.webp",
    tekst:
      "De laatste kilometer naar de zee wilde ze toch heel graag nog even zelf doen!",
    orientatie: "landscape",
  },
  {
    bestand: "finish.webp",
    tekst: "Ja, gehaald! Moe, maar voldaan en super trots!",
    orientatie: "landscape",
  },
  {
    bestand: "dikkekus.mp3",
    tekst:
      "Het hele gezin stuurde bedankjes en dikke duimen voor Eva via Whatsapp. Dit was haar reactie.",
  },
  {
    bestand: "zwemmen.webp",
    tekst: "Als kers op de taart nam ze nog even een verfrissende duik in zee.",
    orientatie: "landscape",
  },
  {
    bestand: "ijsje.webp",
    tekst: "En op de terugweg lekker een ijsje in de trein. Wat een dag!",
    orientatie: "landscape",
  },
];

const fotos70km: Foto[] = [
  {
    bestand: "start.webp",
    tekst: "Vol goede moed aan de start in Driebergen",
    orientatie: "landscape",
  },
  {
    bestand: "koeien.webp",
    tekst:
      "Als tijdverdrijf hielt Eva bij welke dieren we allemaal tegenkwamen. Hier de koeien,",
    orientatie: "landscape",
  },
  {
    bestand: "varkentje.webp",
    tekst: "een lief varkentje,",
    orientatie: "portrait-mid",
  },
  {
    bestand: "lamas.webp",
    tekst: "en zelfs lama's ziet Eva onderweg!",
    orientatie: "landscape",
  },
  {
    bestand: "leersum.webp",
    tekst: "Al snel kwam Eva door Leersum",
    orientatie: "landscape",
  },
  {
    bestand: "heuvel.webp",
    tekst: "De Utrechtse Heuvelrug was mooi, maar niet altijd even makkelijk",
    orientatie: "landscape",
  },
  {
    bestand: "rust.webp",
    tekst: "Tijd voor een beetje rust",
    orientatie: "landscape",
  },
  {
    bestand: "cola.webp",
    tekst: "En wat extra energie tanken",
    orientatie: "landscape",
  },
  {
    bestand: "verder.webp",
    tekst:
      "Hier ging Eva het vorige record voorbij en was ze vol energie voor het laatste stuk",
    orientatie: "landscape",
  },
  {
    bestand: "arnhem.webp",
    tekst:
      "Al binnen de stadsgrenzen van Arnhem. Maar oh jee, zo komt de volle 70 kilometer niet op de teller. Dat werd een extra lus door een buitenwijk, met steile heuvels. Eva op haar tandvlees omhoog en naar beneden.",
    orientatie: "landscape",
  },
  {
    bestand: "finish.webp",
    tekst:
      "Eindelijk, precies 70.0 kilometer gereden. Meteen afstappen en uithijgen.",
    orientatie: "landscape",
  },
  {
    bestand: "lachen.webp",
    tekst: "Al snel na de finish kan Eva weer lachen, het is gelukt!",
    orientatie: "landscape",
  },
  {
    bestand: "ijsje.webp",
    tekst: "En uiteraard het inmiddels traditionele ijsje om het te vieren!",
    orientatie: "portrait-mid",
  },
];

const fotoStijl = (o: Orientatie | undefined) => {
  if (o === "landscape")
    return { container: "w-full aspect-video", positie: "object-center" };
  const pos = {
    "portrait-high": "object-top",
    "portrait-mid": "object-center",
    "portrait-low": "object-bottom",
  };
  return {
    container: "w-2/3 mx-auto aspect-[1/1]",
    positie: pos[o ?? "portrait-mid"],
  };
};
---

<Layout
  title="Vorige Tochten"
  beschrijving="Eva fietste al eerder grote afstanden: 60 km toen ze 6 jaar was en 70 km toen ze 7 jaar was. Lees de verhalen."
>
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <div class="text-5xl mb-3"><span class="fiets-rechts">🚴‍♀️</span></div>
        <h1 class="text-4xl font-black mb-3">
          <span class="gradient-tekst">De vorige tochten</span>
        </h1>
        <p class="text-gray-500">
          Eva's fietstraditie — elke keer een stukje meer
        </p>
      </div>

      <!-- Tijdlijn badges -->
      <div class="flex justify-center items-center gap-4 mb-14 flex-wrap">
        <div
          class="bg-turkoois/10 border-2 border-turkoois rounded-full px-5 py-2 text-center"
        >
          <span class="font-black text-turkoois">60 km</span>
          <span class="text-gray-500 text-sm ml-1">· Eva 6 jaar</span>
        </div>
        <div class="text-gray-300 text-2xl">→</div>
        <div
          class="bg-oranje/10 border-2 border-oranje rounded-full px-5 py-2 text-center"
        >
          <span class="font-black text-oranje">70 km</span>
          <span class="text-gray-500 text-sm ml-1">· Eva 7 jaar</span>
        </div>
        <div class="text-gray-300 text-2xl">→</div>
        <div
          class="bg-geel/20 border-2 border-geel rounded-full px-5 py-2 text-center"
        >
          <span class="font-black text-donker">100 km</span>
          <span class="text-gray-500 text-sm ml-1">· Eva 10 jaar ✨</span>
        </div>
      </div>

      <!-- Twee kolommen: 60 km links, 70 km rechts -->
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <!-- Linker kolom: 60 km tocht -->
        <div
          class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden"
        >
          <div
            class="bg-turkoois/10 border-b border-turkoois/20 px-6 py-5 text-center"
          >
            <div class="text-4xl font-black text-turkoois mb-1">60 km</div>
            <div class="text-gray-500 font-semibold">Eva was 6 jaar oud</div>
          </div>

          <div class="p-6 space-y-4 text-gray-600 leading-relaxed">
            <p>
              De allereerste grote fietstocht! Samen met haar vader Erik fietste
              Eva
              <strong>60 kilometer</strong> op één dag — toen ze nog maar 6 jaar oud
              was. Een ongelooflijke prestatie voor zo'n kleine wielrenner.
            </p>
            <p>
              Het grote plan was om vanuit Driebergen naar de zee te fietsen.
              Eva zolang als ze kon zelf fietsen en daarna achterhangen met de <a
                href="https://followme-tandem.nl/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-500 hover:underline"
                ><strong>follow-me</strong></a
              >. Vooraf dacht ze "misschien haal ik 10 of 20 kilometer", maar ze
              ging maar door en door...
            </p>
          </div>

          <!-- Foto's 60 km -->
          <div class="px-6 pb-6">
            {
              fotos60km.length > 0 ? (
                <div class="flex flex-col gap-4">
                  {fotos60km.map((foto, i) => {
                    const isAudio = foto.bestand.endsWith(".mp3");
                    const { container, positie } = fotoStijl(foto.orientatie);
                    return (
                      <figure class="flex flex-col">
                        {isAudio ? (
                          <audio
                            controls
                            class="w-full rounded-xl"
                            aria-label={
                              foto.tekst || `Geluidsfragment ${i + 1}`
                            }
                          >
                            <source
                              src={`/media/vorige-tochten/60km/${foto.bestand}`}
                              type="audio/mpeg"
                            />
                          </audio>
                        ) : (
                          <div
                            class={`overflow-hidden rounded-xl ${container}`}
                          >
                            <img
                              src={`/media/vorige-tochten/60km/${foto.bestand}`}
                              alt={
                                foto.tekst || `Foto ${i + 1} van de 60 km tocht`
                              }
                              class={`w-full h-full object-cover ${positie}`}
                              loading="lazy"
                            />
                          </div>
                        )}
                        {foto.tekst && (
                          <figcaption class="text-gray-600 leading-relaxed mt-2">
                            {foto.tekst}
                          </figcaption>
                        )}
                      </figure>
                    );
                  })}
                </div>
              ) : (
                <div class="bg-turkoois/5 rounded-2xl p-6 text-center text-gray-400 border-2 border-dashed border-turkoois/20">
                  <p class="text-3xl mb-2">📸</p>
                  <p class="text-sm">Foto's komen binnenkort!</p>
                </div>
              )
            }
          </div>
        </div>

        <!-- Rechter kolom: 70 km tocht -->
        <div
          class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden"
        >
          <div
            class="bg-oranje/10 border-b border-oranje/20 px-6 py-5 text-center"
          >
            <div class="text-4xl font-black text-oranje mb-1">70 km</div>
            <div class="text-gray-500 font-semibold">Eva was 7 jaar oud</div>
          </div>

          <div class="p-6 space-y-4 text-gray-600 leading-relaxed">
            <p>
              Een jaar later, een 'trapje' verder. Maar liefst <strong
                >70 kilometer</strong
              > deze keer — ook samen met papa Erik. Want als je weet dat je ver kunt
              gaan, dan wil je de volgende keer natuurlijk nóg verder!
            </p>
            <p>
              Het plan was van tevoren al om de volle 70 kilometer zelf te
              fietsen, papa mocht zelfs geen duwtje geven. De route was nu
              precies de andere kant op, met Arnhem als eindbestemming.
            </p>
          </div>

          <!-- Foto's 70 km -->
          <div class="px-6 pb-6">
            {
              fotos70km.length > 0 ? (
                <div class="flex flex-col gap-4">
                  {fotos70km.map((foto, i) => {
                    const isAudio = foto.bestand.endsWith(".mp3");
                    const { container, positie } = fotoStijl(foto.orientatie);
                    return (
                      <figure class="flex flex-col">
                        {isAudio ? (
                          <audio
                            controls
                            class="w-full rounded-xl"
                            aria-label={
                              foto.tekst || `Geluidsfragment ${i + 1}`
                            }
                          >
                            <source
                              src={`/media/vorige-tochten/70km/${foto.bestand}`}
                              type="audio/mpeg"
                            />
                          </audio>
                        ) : (
                          <div
                            class={`overflow-hidden rounded-xl ${container}`}
                          >
                            <img
                              src={`/media/vorige-tochten/70km/${foto.bestand}`}
                              alt={
                                foto.tekst || `Foto ${i + 1} van de 70 km tocht`
                              }
                              class={`w-full h-full object-cover ${positie}`}
                              loading="lazy"
                            />
                          </div>
                        )}
                        {foto.tekst && (
                          <figcaption class="text-gray-600 leading-relaxed mt-2">
                            {foto.tekst}
                          </figcaption>
                        )}
                      </figure>
                    );
                  })}
                </div>
              ) : (
                <div class="bg-oranje/5 rounded-2xl p-6 text-center text-gray-400 border-2 border-dashed border-oranje/20">
                  <p class="text-3xl mb-2">📸</p>
                  <p class="text-sm">Foto's komen binnenkort!</p>
                </div>
              )
            }
          </div>
        </div>
      </div>

      <!-- Onderkant: aanmoediging voor de 100 km -->
      <div
        class="mt-12 text-center bg-gradient-to-r from-turkoois/10 to-oranje/10 rounded-3xl p-8 border border-gray-100"
      >
        <p class="text-xl font-bold text-donker mb-2">
          En nu? <span class="gradient-tekst">100 kilometer!</span>
        </p>
        <p class="text-gray-500">
          Eva is inmiddels 10 jaar, en ze gaat voor haar grootste avontuur ooit.
          Haar ambitie is om de volle <strong>100 kilometer</strong> op de teller
          te krijgen.
          <br />
          Op naar de finish en naar Lissabon in 2027! Steun haar door te doneren —
          elk beetje helpt!
        </p>
        <a
          href="/doneer"
          class="inline-block mt-4 bg-oranje text-white font-black px-6 py-3 rounded-full hover:bg-oranje/90 transition-colors"
        >
          <span class="fiets-rechts">🚴‍♀️</span> Steun Eva en Unitas 🤸‍♀️
        </a>
      </div>
    </div>
  </section>
</Layout>
