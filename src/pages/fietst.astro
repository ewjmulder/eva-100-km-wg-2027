---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Eva Fietst!" beschrijving="Zo ver is Eva virtueel al gefietst — dankzij jullie donaties!">
  <section class="min-h-screen bg-gradient-to-b from-sky-50 via-blue-50 to-green-50 pt-24 pb-16 px-4">
    <div class="max-w-4xl mx-auto">

      <!-- Titel -->
      <div class="text-center mb-8">
        <h1 class="text-5xl font-black mb-3"><span class="gradient-tekst">Eva Fietst!</span> 🚴‍♀️</h1>
        <p class="text-gray-500 text-lg">Jullie donaties brengen Eva dichter bij de finish.</p>
      </div>

      <!-- Fietstocht scene -->
      <div class="rounded-3xl overflow-hidden shadow-2xl border-4 border-white">
        <svg id="tocht-scene" viewBox="0 0 1000 300" xmlns="http://www.w3.org/2000/svg" class="w-full block">
          <defs>
            <linearGradient id="lucht" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#42A5F5"/>
              <stop offset="100%" stop-color="#90CAF9"/>
            </linearGradient>
            <linearGradient id="gras" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#66BB6A"/>
              <stop offset="100%" stop-color="#43A047"/>
            </linearGradient>
            <linearGradient id="weg" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#BDBDBD"/>
              <stop offset="100%" stop-color="#9E9E9E"/>
            </linearGradient>
          </defs>

          <!-- Lucht -->
          <rect width="1000" height="300" fill="url(#lucht)"/>

          <!-- Zon + gloed -->
          <circle cx="900" cy="65" r="75" fill="#FFF9C4" opacity="0.35"/>
          <circle cx="900" cy="65" r="52" fill="#FFF176" opacity="0.9"/>

          <!-- Wolk 1 -->
          <g>
            <ellipse cx="0" cy="68" rx="55" ry="26" fill="white" opacity="0.92"/>
            <ellipse cx="-38" cy="76" rx="38" ry="21" fill="white" opacity="0.92"/>
            <ellipse cx="38" cy="78" rx="44" ry="20" fill="white" opacity="0.92"/>
            <animateTransform attributeName="transform" type="translate"
              from="-50 0" to="1200 0" dur="38s" repeatCount="indefinite"/>
          </g>

          <!-- Wolk 2 -->
          <g>
            <ellipse cx="0" cy="48" rx="65" ry="25" fill="white" opacity="0.85"/>
            <ellipse cx="-45" cy="58" rx="45" ry="20" fill="white" opacity="0.85"/>
            <ellipse cx="50" cy="60" rx="48" ry="18" fill="white" opacity="0.85"/>
            <animateTransform attributeName="transform" type="translate"
              from="350 0" to="1600 0" dur="52s" repeatCount="indefinite"/>
          </g>

          <!-- Wolk 3 (langzaam) -->
          <g>
            <ellipse cx="0" cy="88" rx="48" ry="22" fill="white" opacity="0.8"/>
            <ellipse cx="-35" cy="96" rx="32" ry="17" fill="white" opacity="0.8"/>
            <animateTransform attributeName="transform" type="translate"
              from="-200 0" to="1100 0" dur="64s" repeatCount="indefinite"/>
          </g>

          <!-- Verre heuvels -->
          <ellipse cx="220" cy="215" rx="290" ry="110" fill="#A5D6A7" opacity="0.35"/>
          <ellipse cx="760" cy="220" rx="260" ry="100" fill="#81C784" opacity="0.30"/>

          <!-- Gras -->
          <rect x="0" y="215" width="1000" height="85" fill="url(#gras)"/>

          <!-- Bloempjes in het gras -->
          <circle cx="105" cy="228" r="3" fill="#FFF176"/>
          <circle cx="195" cy="232" r="2.5" fill="#FF8A80"/>
          <circle cx="310" cy="225" r="3" fill="white"/>
          <circle cx="440" cy="230" r="2.5" fill="#FFF176"/>
          <circle cx="560" cy="226" r="3" fill="#FF8A80"/>
          <circle cx="680" cy="229" r="2.5" fill="white"/>
          <circle cx="800" cy="227" r="3" fill="#FFF176"/>
          <circle cx="880" cy="231" r="2.5" fill="#FF8A80"/>

          <!-- Weg -->
          <rect x="0" y="238" width="1000" height="52" fill="url(#weg)"/>
          <rect x="0" y="238" width="1000" height="1.5" fill="#E0E0E0"/>
          <rect x="0" y="289" width="1000" height="1.5" fill="#757575"/>

          <!-- Wegstrepen (wit gestippeld) -->
          <rect x="0"   y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>
          <rect x="105" y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>
          <rect x="210" y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>
          <rect x="315" y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>
          <rect x="420" y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>
          <rect x="525" y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>
          <rect x="630" y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>
          <rect x="735" y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>
          <rect x="840" y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>
          <rect x="945" y="262" width="68" height="5" fill="white" opacity="0.75" rx="2.5"/>

          <!-- Boom 1 -->
          <rect x="116" y="175" width="8" height="52" fill="#5D4037"/>
          <ellipse cx="120" cy="164" rx="22" ry="28" fill="#2E7D32"/>
          <ellipse cx="120" cy="158" rx="16" ry="18" fill="#388E3C"/>

          <!-- Boom 2 -->
          <rect x="376" y="178" width="8" height="49" fill="#5D4037"/>
          <ellipse cx="380" cy="167" rx="20" ry="26" fill="#1B5E20"/>
          <ellipse cx="380" cy="161" rx="14" ry="17" fill="#2E7D32"/>

          <!-- Boom 3 -->
          <rect x="606" y="176" width="8" height="51" fill="#5D4037"/>
          <ellipse cx="610" cy="165" rx="21" ry="27" fill="#2E7D32"/>
          <ellipse cx="610" cy="159" rx="15" ry="18" fill="#388E3C"/>

          <!-- Boom 4 -->
          <rect x="838" y="179" width="8" height="48" fill="#5D4037"/>
          <ellipse cx="842" cy="168" rx="19" ry="25" fill="#1B5E20"/>
          <ellipse cx="842" cy="163" rx="13" ry="16" fill="#2E7D32"/>

          <!-- START vlag -->
          <rect x="42" y="192" width="3.5" height="48" fill="#424242"/>
          <polygon points="45.5,192 72,202 45.5,214" fill="#00C4B4"/>
          <text x="46" y="295" font-size="9.5" fill="#616161" font-family="sans-serif" font-weight="bold" text-anchor="middle">START</text>

          <!-- 25 km mijlpaal -->
          <rect x="284" y="198" width="3" height="42" fill="#9E9E9E"/>
          <rect x="287" y="198" width="34" height="18" fill="#FDD835" rx="3"/>
          <text x="304" y="211" font-size="10" fill="#333" font-family="sans-serif" font-weight="bold" text-anchor="middle">25 km</text>

          <!-- 50 km mijlpaal -->
          <rect x="524" y="195" width="3" height="45" fill="#9E9E9E"/>
          <rect x="527" y="195" width="34" height="18" fill="#FF6B35" rx="3"/>
          <text x="544" y="208" font-size="10" fill="white" font-family="sans-serif" font-weight="bold" text-anchor="middle">50 km</text>

          <!-- 75 km mijlpaal -->
          <rect x="763" y="198" width="3" height="42" fill="#9E9E9E"/>
          <rect x="766" y="198" width="34" height="18" fill="#FDD835" rx="3"/>
          <text x="783" y="211" font-size="10" fill="#333" font-family="sans-serif" font-weight="bold" text-anchor="middle">75 km</text>

          <!-- FINISH geruite vlag -->
          <rect x="952" y="186" width="3.5" height="54" fill="#424242"/>
          <!-- Geruite vlag 4x2 blokjes -->
          <rect x="955.5" y="186" width="10" height="10" fill="#333"/>
          <rect x="965.5" y="186" width="10" height="10" fill="white"/>
          <rect x="975.5" y="186" width="10" height="10" fill="#333"/>
          <rect x="955.5" y="196" width="10" height="10" fill="white"/>
          <rect x="965.5" y="196" width="10" height="10" fill="#333"/>
          <rect x="975.5" y="196" width="10" height="10" fill="white"/>
          <text x="970" y="295" font-size="9.5" fill="#616161" font-family="sans-serif" font-weight="bold" text-anchor="middle">100 km</text>

          <!-- ═══════════════════════════════════════════
               FIETS + EVA (gepositioneerd via JS)
               Origine: (X, 238) = wegoppervlak
               Wielen raken de weg op y=0 → center y=-20
          ═══════════════════════════════════════════ -->
          <g id="fiets-groep">

            <!-- Achterwiel met spaken -->
            <g transform="translate(-22,-20)">
              <g>
                <circle cx="0" cy="0" r="20" fill="none" stroke="#212121" stroke-width="2.5"/>
                <circle cx="0" cy="0" r="4" fill="#616161"/>
                <line x1="0" y1="-16" x2="0" y2="16" stroke="#757575" stroke-width="1.5"/>
                <line x1="-16" y1="0" x2="16" y2="0" stroke="#757575" stroke-width="1.5"/>
                <line x1="-11" y1="-11" x2="11" y2="11" stroke="#757575" stroke-width="1"/>
                <line x1="11" y1="-11" x2="-11" y2="11" stroke="#757575" stroke-width="1"/>
                <animateTransform attributeName="transform" type="rotate"
                  from="0 0 0" to="360 0 0" dur="0.7s" repeatCount="indefinite"/>
              </g>
            </g>

            <!-- Voorwiel met spaken -->
            <g transform="translate(22,-20)">
              <g>
                <circle cx="0" cy="0" r="20" fill="none" stroke="#212121" stroke-width="2.5"/>
                <circle cx="0" cy="0" r="4" fill="#616161"/>
                <line x1="0" y1="-16" x2="0" y2="16" stroke="#757575" stroke-width="1.5"/>
                <line x1="-16" y1="0" x2="16" y2="0" stroke="#757575" stroke-width="1.5"/>
                <line x1="-11" y1="-11" x2="11" y2="11" stroke="#757575" stroke-width="1"/>
                <line x1="11" y1="-11" x2="-11" y2="11" stroke="#757575" stroke-width="1"/>
                <animateTransform attributeName="transform" type="rotate"
                  from="0 0 0" to="360 0 0" dur="0.7s" repeatCount="indefinite"/>
              </g>
            </g>

            <!-- Frame (oranje) -->
            <!-- Chainstay: BB naar achterwiel -->
            <line x1="-3" y1="-22" x2="-22" y2="-20" stroke="#FF6B35" stroke-width="2.5" stroke-linecap="round"/>
            <!-- Seatstay: achterwiel naar zadelpen top -->
            <line x1="-22" y1="-20" x2="-8" y2="-50" stroke="#FF6B35" stroke-width="2" stroke-linecap="round"/>
            <!-- Seat tube: BB naar zadelpen top -->
            <line x1="-3" y1="-22" x2="-8" y2="-50" stroke="#FF6B35" stroke-width="3" stroke-linecap="round"/>
            <!-- Top tube: zadelpen naar stuurpijp -->
            <line x1="-8" y1="-50" x2="18" y2="-42" stroke="#FF6B35" stroke-width="3" stroke-linecap="round"/>
            <!-- Down tube: BB naar stuurpijp -->
            <line x1="-3" y1="-22" x2="18" y2="-42" stroke="#FF6B35" stroke-width="3" stroke-linecap="round"/>
            <!-- Vork: stuurpijp naar voorwiel -->
            <line x1="18" y1="-42" x2="22" y2="-20" stroke="#FF6B35" stroke-width="2.5" stroke-linecap="round"/>

            <!-- Trapas -->
            <circle cx="-3" cy="-22" r="5" fill="#FF6B35" stroke="#E55A2B" stroke-width="1"/>

            <!-- Pedalen (beweegbaar) -->
            <g>
              <line x1="-11" y1="-18" x2="5" y2="-26" stroke="#424242" stroke-width="2.5" stroke-linecap="round"/>
              <rect x="-14" y="-20" width="6" height="3" fill="#333" rx="1"/>
              <rect x="3" y="-28" width="6" height="3" fill="#333" rx="1"/>
              <animateTransform attributeName="transform" type="rotate"
                from="0 -3 -22" to="360 -3 -22" dur="0.7s" repeatCount="indefinite"/>
            </g>

            <!-- Stuur -->
            <line x1="18" y1="-42" x2="26" y2="-46" stroke="#333" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="26" y1="-46" x2="26" y2="-38" stroke="#333" stroke-width="3" stroke-linecap="round"/>

            <!-- Zadel -->
            <line x1="-8" y1="-50" x2="-8" y2="-54" stroke="#424242" stroke-width="2"/>
            <rect x="-18" y="-57" width="20" height="5" fill="#424242" rx="2.5"/>

            <!-- ── Eva ── -->
            <!-- Lichaam (turquoise truitje, gebogen voorover) -->
            <path d="M -12,-54 Q 2,-56 18,-46" fill="none" stroke="#00C4B4" stroke-width="11" stroke-linecap="round"/>
            <!-- Arm naar stuur -->
            <line x1="18" y1="-46" x2="26" y2="-42" stroke="#FDBCB4" stroke-width="4" stroke-linecap="round"/>

            <!-- Hoofd -->
            <circle cx="4" cy="-69" r="11" fill="#FDBCB4" stroke="#E8A89A" stroke-width="1.5"/>

            <!-- Haar (donkerbruin, vlechtje opzij) -->
            <path d="M -6,-75 Q 4,-84 14,-75" stroke="#5D4037" stroke-width="4.5" fill="none" stroke-linecap="round"/>
            <path d="M 13,-74 Q 20,-72 20,-62" stroke="#5D4037" stroke-width="3.5" fill="none" stroke-linecap="round"/>
            <!-- Haarbandje -->
            <circle cx="13" cy="-74" r="3" fill="#FF6B35"/>

            <!-- Oogjes -->
            <circle cx="1" cy="-69" r="1.5" fill="#333"/>
            <circle cx="7" cy="-69" r="1.5" fill="#333"/>
            <!-- Lachend mondje -->
            <path d="M 0,-65 Q 4,-62 8,-65" stroke="#C06060" stroke-width="1.5" fill="none" stroke-linecap="round"/>

            <!-- Wangetjes -->
            <circle cx="0" cy="-67" r="3" fill="#FFB3A3" opacity="0.5"/>
            <circle cx="8" cy="-67" r="3" fill="#FFB3A3" opacity="0.5"/>

            <!-- Helm (turquoise) -->
            <path d="M -7,-75 Q 4,-88 15,-75" fill="#00C4B4" opacity="0.8"/>
            <line x1="-7" y1="-75" x2="15" y2="-75" stroke="#00C4B4" stroke-width="2.5"/>
          </g>
        </svg>
      </div>

      <!-- Km teller -->
      <div class="mt-5 text-center">
        <div class="inline-flex items-center gap-3 bg-white rounded-2xl px-8 py-4 shadow-sm border border-gray-100">
          <span class="text-4xl font-black text-turkoois" id="km-getal">…</span>
          <div class="text-left">
            <div class="font-bold text-donker text-lg leading-none">van de 100 km</div>
            <div class="text-gray-400 text-sm">virtueel gefietst</div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-4 mt-4">
        <div class="bg-white rounded-2xl p-5 text-center shadow-sm border border-gray-100">
          <div class="text-3xl font-black text-oranje" id="bedrag-getal">—</div>
          <div class="text-xs text-gray-400 mt-1 font-semibold uppercase tracking-wide">opgehaald van €1.500</div>
        </div>
        <div class="bg-white rounded-2xl p-5 text-center shadow-sm border border-gray-100">
          <div class="text-3xl font-black text-donker" id="donateurs-getal">—</div>
          <div class="text-xs text-gray-400 mt-1 font-semibold uppercase tracking-wide">donateurs</div>
        </div>
      </div>

      <!-- Voortgangsbalk -->
      <div class="mt-4 bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
        <div class="flex justify-between text-sm font-semibold text-gray-400 mb-3">
          <span>🚀 Start</span>
          <span>🏁 Doel: €1.500</span>
        </div>
        <div class="h-5 bg-gray-100 rounded-full overflow-hidden">
          <div id="voortgang-balk"
               class="h-full bg-gradient-to-r from-turkoois to-oranje rounded-full"
               style="width: 0%; transition: width 2s cubic-bezier(0.25, 0.46, 0.45, 0.94)">
          </div>
        </div>
        <div class="flex justify-between text-xs text-gray-300 mt-2">
          <span>0 km</span>
          <span>25 km</span>
          <span>50 km</span>
          <span>75 km</span>
          <span>100 km</span>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-8 text-center">
        <a href="/doneer"
           class="inline-block bg-gradient-to-r from-turkoois to-oranje text-white font-black px-10 py-4 rounded-full text-xl hover:scale-105 transition-transform shadow-xl">
          🚴‍♀️ Help Eva verder fietsen
        </a>
        <p class="text-gray-400 text-sm mt-3">Elke euro brengt haar dichter bij de finish</p>
      </div>

    </div>
  </section>
</Layout>

<script>
  import { haalDonaties, berekenTotaal } from '../lib/donations';

  const DOEL = 1500;

  // SVG-coördinaten: fiets rijdt van x=55 (bij startvlag) tot x=935 (bij finishvlag)
  // De fiets-groep origine zit op het wegoppervlak (y=238 in de SVG)
  const START_X = 55;
  const EIND_X  = 935;
  const WEG_Y   = 238;

  function animeerNaar(element: SVGElement, naarX: number) {
    const vanX = START_X;
    const duur = 2000; // ms
    const start = performance.now();

    // Begin altijd bij START_X
    element.setAttribute('transform', `translate(${vanX}, ${WEG_Y})`);

    function stap(nu: number) {
      const t = Math.min((nu - start) / duur, 1);
      // Ease-out cubic
      const ease = 1 - Math.pow(1 - t, 3);
      const x = vanX + (naarX - vanX) * ease;
      element.setAttribute('transform', `translate(${x}, ${WEG_Y})`);
      if (t < 1) requestAnimationFrame(stap);
    }

    // Klein vertraagje zodat de browser eerst schildert
    setTimeout(() => requestAnimationFrame(stap), 150);
  }

  async function laadVoortgang() {
    const donaties = await haalDonaties();
    const totaal   = berekenTotaal(donaties);
    const pct      = Math.min(totaal / DOEL, 1);
    const km       = Math.round(pct * 100);

    // Fiets bewegen
    const fiets = document.getElementById('fiets-groep') as SVGElement | null;
    if (fiets) {
      const bikeX = START_X + (EIND_X - START_X) * pct;
      animeerNaar(fiets, bikeX);
    }

    // Km getal
    const kmGetal = document.getElementById('km-getal');
    if (kmGetal) kmGetal.textContent = `${km} km`;

    // Bedrag
    const bedragGetal = document.getElementById('bedrag-getal');
    if (bedragGetal) {
      bedragGetal.textContent = totaal.toLocaleString('nl-NL', {
        style: 'currency',
        currency: 'EUR',
        maximumFractionDigits: 0,
      });
    }

    // Donateurs
    const donateursGetal = document.getElementById('donateurs-getal');
    if (donateursGetal) donateursGetal.textContent = String(donaties.length);

    // Voortgangsbalk (iets vertraagd voor smooth effect)
    const balk = document.getElementById('voortgang-balk');
    if (balk) setTimeout(() => { balk.style.width = `${pct * 100}%`; }, 200);
  }

  laadVoortgang();
</script>
