      <!-- Stats -->
      <div class="grid grid-cols-2 gap-4 mt-4">
        <div
          class="bg-white rounded-2xl p-5 text-center shadow-sm border border-gray-100"
        >
          <div class="text-3xl font-black text-oranje" id="bedrag-getal">—</div>
          <div
            class="text-xs text-gray-400 mt-1 font-semibold uppercase tracking-wide"
          >
            opgehaald van €1.500
          </div>
        </div>
        <div
          class="bg-white rounded-2xl p-5 text-center shadow-sm border border-gray-100"
        >
          <div class="text-3xl font-black text-donker" id="donateurs-getal">
            —
          </div>
          <div
            class="text-xs text-gray-400 mt-1 font-semibold uppercase tracking-wide"
          >
            donateurs
