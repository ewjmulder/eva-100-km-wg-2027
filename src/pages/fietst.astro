      <!-- Voortgangsbalk -->
      <div
        class="mt-4 bg-white rounded-2xl p-5 shadow-sm border border-gray-100"
      >
        <div
          class="flex justify-between text-sm font-semibold text-gray-400 mb-3"
        >
          <span>🚀 Start</span>
          <span>🏁 Doel: €1.500</span>
