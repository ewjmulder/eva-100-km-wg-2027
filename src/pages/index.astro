---
import Layout from "../layouts/Layout.astro";
import FietstochtAnimatie from "../components/FietstochtAnimatie.astro";
import RecenteDonateurs from "../components/RecenteDonateurs.astro";
---

<Layout title="Eva Fietst 100 km!">
  <!-- ═══ Eva Fietst! sectie (was /fietst pagina) ═══ -->
  <section
    class="min-h-screen bg-gradient-to-b from-sky-50 via-blue-50 to-green-50 pt-24 pb-16 px-4"
  >
    <div class="max-w-4xl mx-auto">
      <!-- Titel -->
      <div class="mb-8">
        <div class="grid place-items-center mb-3">
          <div class="relative inline-flex items-center">
            <div
              class="absolute right-full mr-4 w-32 h-32 rounded-full overflow-hidden border-4 border-white shadow-[0_12px_28px_rgba(15,23,42,0.22)]"
            >
              <img
                src="/images/Eva.webp"
                alt="Eva"
                class="w-full h-full object-cover"
                loading="eager"
                decoding="async"
              />
            </div>
            <h1 class="text-5xl font-black text-center">
              <span class="gradient-tekst">Eva Fietst!</span>
              <span class="fiets-rechts">🚴‍♀️</span>
            </h1>
          </div>
        </div>
        <p class="text-gray-500 text-lg text-center sm:text-left">
          Eva (10) is turnster bij <a
            href="https://www.unitasdoorn.nl/"
            target="_blank"
            class="text-blue-500 hover:underline"
            ><strong>Unitas in Doorn</strong></a
          > en droomt ervan om mee te doen aan de <a
            href="https://www.ginastica.org/wg2027"
            target="_blank"
            class="text-blue-500 hover:underline"
            ><strong>World Gymnaestrada 2027</strong></a
          > in Lissabon, Portugal. Om geld in te zamelen voor de reis, gaat ze in 1
          dag 100 kilometer fietsen met haar vader Erik. Je kan haar steunen door een
          bedrag per gereden kilometer te sponseren, alvast bedankt!
        </p>
      </div>

      <FietstochtAnimatie />

      <!-- CTA -->
      <div class="mt-8 text-center">
        <a
          href="/doneer"
          class="inline-block bg-gradient-to-r from-turkoois to-oranje text-white font-black px-10 py-4 rounded-full text-xl hover:scale-105 transition-transform shadow-xl"
        >
          <span class="fiets-rechts">🚴‍♀️</span> Help Eva verder fietsen
        </a>
        <p class="text-gray-400 text-sm mt-3">
          Elke euro brengt haar dichter bij de finish
        </p>
      </div>
    </div>
  </section>

  <RecenteDonateurs />
</Layout>
